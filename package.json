{
	"name": "ticket-bot",
	"version": "4.0.0",
	"description": "Open-source Discord ticket bot.",
	"main": "src/index.ts",
	"scripts": {
		"start": "bun src/index.ts",
		"deploy:commands": "bun src/deploy-commands.ts",
		"typecheck": "tsgo --noEmit",
		"format": "biome format",
		"format:fix": "biome format --write",
		"lint": "biome lint",
		"i18n": "bunx typesafe-i18n --no-watch"
	},
	"dependencies": {
		"@discordjs/core": "2.4.0",
		"@discordjs/rest": "^2.6.1",
		"@discordjs/ws": "^2.0.4",
		"@libsql/client": "^0.17.2",
		"discord-api-types": "^0.38.44",
		"dotenv": "^17.4.1",
		"drizzle-orm": "^0.45.2",
		"typesafe-i18n": "^5.27.1"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.10",
		"@types/bun": "^1.3.11",
		"@typescript/native-preview": "^7.0.0-dev.20260409.1",
		"drizzle-kit": "^0.31.10"
	}
}
