{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"allowJs": false,
		"module": "ESNext",
		"moduleResolution": "bundler",
		"noEmit": false,
		"outDir": "./dist",
		"rootDir": ".",
		"sourceMap": true
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts", "config/**/*.ts", "i18n/**/*.ts", "messages/**/*.ts", "drizzle.config.ts"],
	"exclude": ["dist", "node_modules"]
}
